# environments/dev/terraform.tfvars.example
#
# Copy to terraform.tfvars and fill in real values. terraform.tfvars itself
# is gitignored.

location             = "canadacentral"
resource_group_name  = "rg-claims-platform-dev"
admin_username       = "northwindadmin"
ssh_public_key_path  = "/c/Users/satya/.ssh/id_rsa.pub"

tags = {
  Environment        = "dev"
  CostCenter         = "northwind-claims"
  Owner              = "satyadeep"
  DataClassification = "sensitive-claims"
}